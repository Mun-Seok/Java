package day11;

import java.util.Scanner;

public class breakEX1 {

	public static void main(String[] args) {
		Scanner sc=new Scanner(System.in);
		int num;
		while(true) {
			System.out.println("숫자입력");
			num=sc.nextInt();
			if(num==0) {
				System.out.println("반복종료~");
				break;
			}
			System.out.println("i:"+num);
		}
	}

}
